# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://crm:crm_password@localhost:5432/real_estate_crm?schema=public

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
REFRESH_TOKEN_TTL_DAYS_REMEMBER=30

# ---- File storage ----
# If Cloudinary vars are empty, files are stored on local disk under ./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_UPLOAD_MB=10

# ---- SMTP (optional — password reset / reminder emails; logged to console when empty) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=crm@example.com
