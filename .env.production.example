# ============================================================
#  Real Estate CRM — production environment
#  Copy to ".env" (same folder as docker-compose.prod.yml) and fill in.
# ============================================================

# ---- White-label company name ----
# Shown in the sidebar, login page, browser tab and installed-app name.
# Set this per client (e.g. "Sharma Properties CRM").
APP_NAME=Real Estate CRM

# ---- Your domain (already on Hostinger) ----
DOMAIN=crm.yourdomain.com
# Email for the Let's Encrypt SSL certificate (renewal notices).
TLS_EMAIL=you@yourdomain.com

# ---- Database (runs inside Docker on this server) ----
POSTGRES_USER=crm
# Use a long random password:  openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_long_random_db_password
POSTGRES_DB=real_estate_crm

# ---- Auth secrets — generate EACH with:  openssl rand -hex 48 ----
JWT_ACCESS_SECRET=CHANGE_ME_run_openssl_rand_hex_48
JWT_REFRESH_SECRET=CHANGE_ME_different_openssl_rand_hex_48
ACCESS_TOKEN_TTL=15m

# ---- First admin login (created automatically on first boot) ----
ADMIN_NAME=Piyush Soni
ADMIN_MOBILE=9000000001
# Strong password (min 8 chars) — you'll log in with this.
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ---- Optional: Cloudinary CDN for images/brochures ----
# Leave blank to store uploads on the server disk (persisted in a Docker volume).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_UPLOAD_MB=10
