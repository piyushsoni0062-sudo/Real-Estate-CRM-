# ---- Build the React SPA ----
FROM node:22-alpine AS build
WORKDIR /app
# White-label app name baked into the build (sidebar, login, title, PWA).
ARG VITE_APP_NAME="Real Estate CRM"
ENV VITE_APP_NAME=$VITE_APP_NAME
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ---- Serve it with Caddy (automatic HTTPS) ----
FROM caddy:2-alpine
COPY --from=build /app/dist /srv
COPY Caddyfile /etc/caddy/Caddyfile
EXPOSE 80 443
